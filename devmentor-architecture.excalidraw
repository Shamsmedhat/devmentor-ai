      "link": null,
      "locked": false,
      "text": "src/proxy.ts \u2014 MIDDLEWARE\n(Next.js 16 renames middleware.ts \u2192 proxy.ts)\n\u2022 next-intl createMiddleware(routing) handles ar/en redirects + cookie\n\u2022 Then Supabase: createServerClient + getUser() refreshes session cookies on the response\n\u2022 If pathname is /chat or /review and !user \u2192 302 /[locale]/login?next=\u2026\n\u2022 If pathname is /login and user \u2192 302 safeNextPath()\nmatcher: /((?!api|_next|_vercel|.*\\..*).*)",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": "r-mw",
      "originalText": "src/proxy.ts \u2014 MIDDLEWARE\n(Next.js 16 renames middleware.ts \u2192 proxy.ts)\n\u2022 next-intl createMiddleware(routing) handles ar/en redirects + cookie\n\u2022 Then Supabase: createServerClient + getUser() refreshes session cookies on the response\n\u2022 If pathname is /chat or /review and !user \u2192 302 /[locale]/login?next=\u2026\n\u2022 If pathname is /login and user \u2192 302 safeNextPath()\nmatcher: /((?!api|_next|_vercel|.*\\..*).*)",
      "lineHeight": 1.25,
      "autoResize": false
    },
