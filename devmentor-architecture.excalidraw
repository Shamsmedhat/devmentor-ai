    {
      "id": "t-actions",
      "type": "text",
      "x": 1608,
      "y": 1948,
      "width": 444,
      "height": 324,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 8002,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1714000000000,
      "link": null,
      "locked": false,
      "text": "SERVER ACTIONS  ('use server')\nsrc/lib/actions/chat.action.ts\nAll receive { userId } and use createClient() (server)\n\n\u2022 getChatSessionsAction({userId})\n   \u2192 chatService.getChatSessions(supabase,userId)\n   \u2192 ChatSession[]\n\n\u2022 getChatMessagesAction({userId,sessionId})\n   verifies session.user_id === userId, then\n   \u2192 chatService.getChatMessages(supabase, sessionId)\n   \u2192 ChatMessage[]\n\n\u2022 createChatSessionAction({userId,title?})\n   INSERT chat_sessions(user_id,title) \u2192 {id,title}\n   revalidatePath('/[locale]/chat')\n\n\u2022 saveChatMessageAction({sessionId,userId,role,content})\n   verifies ownership, INSERT chat_messages\n   UPDATE chat_sessions.updated_at = now()\n\n\u2022 updateSessionTitleAction({sessionId,userId,title})\n   verifies ownership, UPDATE chat_sessions.title",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "SERVER ACTIONS  ('use server')\nsrc/lib/actions/chat.action.ts\nAll receive { userId } and use createClient() (server)\n\n\u2022 getChatSessionsAction({userId})\n   \u2192 chatService.getChatSessions(supabase,userId)\n   \u2192 ChatSession[]\n\n\u2022 getChatMessagesAction({userId,sessionId})\n   verifies session.user_id === userId, then\n   \u2192 chatService.getChatMessages(supabase, sessionId)\n   \u2192 ChatMessage[]\n\n\u2022 createChatSessionAction({userId,title?})\n   INSERT chat_sessions(user_id,title) \u2192 {id,title}\n   revalidatePath('/[locale]/chat')\n\n\u2022 saveChatMessageAction({sessionId,userId,role,content})\n   verifies ownership, INSERT chat_messages\n   UPDATE chat_sessions.updated_at = now()\n\n\u2022 updateSessionTitleAction({sessionId,userId,title})\n   verifies ownership, UPDATE chat_sessions.title",
      "lineHeight": 1.25,
      "autoResize": false
    },
