      "link": null,
      "locked": false,
      "text": "LoginPanel (Server, async)\nlogin/_components/login-panel.tsx\n\u2022 Logo + brain.svg\n\u2022 title + subtitle (next-intl)\n\u2022 Optional 'auth_failed' banner\n\u2022 <GoogleLoginButton nextPath={oauthNextPath}/>\n\u2022 Terms text\n\u2022 Link back to /\nProps: oauthNextPath, showAuthError",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
