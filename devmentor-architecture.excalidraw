      "link": null,
      "locked": false,
      "text": "APP LAYOUT CHAIN\nsrc/app/layout.tsx (root) \u2014 pass-through; imports globals.css\n  \u2193\nsrc/app/[locale]/layout.tsx \u2014 generateStaticParams[ar,en], loads Geist/Cairo,\n  setRequestLocale, getMessages, sets <html dir lang>, wraps in <NextIntlClientProvider>\n  \u2193\n(auth) layout \u2014 centered card on dark bg + dot-grid + <AuthToaster/>\n(dashboard) layout \u2014 pass-through (reserved for chrome)\n\u2192 then the route page below.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": "r-layouts",
      "originalText": "APP LAYOUT CHAIN\nsrc/app/layout.tsx (root) \u2014 pass-through; imports globals.css\n  \u2193\nsrc/app/[locale]/layout.tsx \u2014 generateStaticParams[ar,en], loads Geist/Cairo,\n  setRequestLocale, getMessages, sets <html dir lang>, wraps in <NextIntlClientProvider>\n  \u2193\n(auth) layout \u2014 centered card on dark bg + dot-grid + <AuthToaster/>\n(dashboard) layout \u2014 pass-through (reserved for chrome)\n\u2192 then the route page below.",
      "lineHeight": 1.25,
      "autoResize": false
