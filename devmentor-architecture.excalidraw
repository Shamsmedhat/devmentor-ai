    {
      "id": "t-apichat",
      "type": "text",
      "x": 2108,
      "y": 1948,
      "width": 404,
      "height": 304,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 8004,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1714000000000,
      "link": null,
      "locked": false,
      "text": "POST /api/chat  \u2192  route.ts\nsrc/app/api/chat/route.ts\n\u2022 maxDuration = 30s\n\u2022 Reads {messages, sessionId} from request\n\u2022 createClient() (server) + getUser()\n\u2022 If !user \u2192 401 'Authentication required'\n\u2022 checkChatRateLimit(userId)\n   \u2192 429 if exceeded (resets in <ms>)\n\u2022 normalizeUiMessagesForAttachmentCapabilities(\n     messages, CHAT_MODEL_CAPABILITY_KEY)\n   \u2192 drops/converts unsupported file parts\n\u2022 modelMessages = convertToModelMessages(...)\n\u2022 streamText({\n     model: groq('llama-3.3-70b-versatile'),\n     system: MENTOR_SYSTEM_PROMPT,\n     messages: modelMessages})\n\u2022 return result.toUIMessageStreamResponse()\n  (UIMessage stream protocol \u2192 useChat reads it)",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": "r-apichat",
      "originalText": "POST /api/chat  \u2192  route.ts\nsrc/app/api/chat/route.ts\n\u2022 maxDuration = 30s\n\u2022 Reads {messages, sessionId} from request\n\u2022 createClient() (server) + getUser()\n\u2022 If !user \u2192 401 'Authentication required'\n\u2022 checkChatRateLimit(userId)\n   \u2192 429 if exceeded (resets in <ms>)\n\u2022 normalizeUiMessagesForAttachmentCapabilities(\n     messages, CHAT_MODEL_CAPABILITY_KEY)\n   \u2192 drops/converts unsupported file parts\n\u2022 modelMessages = convertToModelMessages(...)\n\u2022 streamText({\n     model: groq('llama-3.3-70b-versatile'),\n     system: MENTOR_SYSTEM_PROMPT,\n     messages: modelMessages})\n\u2022 return result.toUIMessageStreamResponse()\n  (UIMessage stream protocol \u2192 useChat reads it)",
      "lineHeight": 1.25,
      "autoResize": false
    },
