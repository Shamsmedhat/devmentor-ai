      "link": null,
      "locked": false,
      "text": "useGoogleLogin (HOOK)\nsrc/hooks/auth/use-google-login.ts\nProps: {nextPath?: string}\nState: isPending (useTransition)\nFns:\n\u2022 signInWithGoogle():\n   startTransition(async)\n   \u2192 supabase.auth.signInWithOAuth({\n      provider:'google',\n      options:{redirectTo: <origin>/api/auth/\n        callback?next=<safeNext>}})\n   \u2192 on error \u2192 toast.error(t('error'))\nReturns: {isPending, signInWithGoogle}",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": "r-usegoogle",
      "originalText": "useGoogleLogin (HOOK)\nsrc/hooks/auth/use-google-login.ts\nProps: {nextPath?: string}\nState: isPending (useTransition)\nFns:\n\u2022 signInWithGoogle():\n   startTransition(async)\n   \u2192 supabase.auth.signInWithOAuth({\n      provider:'google',\n      options:{redirectTo: <origin>/api/auth/\n        callback?next=<safeNext>}})\n   \u2192 on error \u2192 toast.error(t('error'))\nReturns: {isPending, signInWithGoogle}",
      "lineHeight": 1.25,
      "autoResize": false
    },
