    {
      "id": "t-ext-supa",
      "type": "text",
      "x": 608,
      "y": 2848,
      "width": 464,
      "height": 224,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 12002,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1714000000000,
      "link": null,
      "locked": false,
      "text": "EXTERNAL: SUPABASE  (cloud)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nAUTH\n\u2022 Google OAuth (PKCE) \u2192 /api/auth/callback\n\u2022 signInWithOAuth, signOut, getUser\n\u2022 Session cookies refreshed by proxy.ts\nDATABASE (Postgres)\n\u2022 chat_sessions(id,user_id,title,\n   created_at,updated_at)\n\u2022 chat_messages(id,session_id,role,\n   content,created_at)\n\u2022 RLS: user_id = auth.uid()\nREALTIME\n\u2022 postgres_changes channel on\n   chat_sessions filtered by user_id \u2014\n   sidebar subscribes to live updates.",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": "r-ext-supa",
      "originalText": "EXTERNAL: SUPABASE  (cloud)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nAUTH\n\u2022 Google OAuth (PKCE) \u2192 /api/auth/callback\n\u2022 signInWithOAuth, signOut, getUser\n\u2022 Session cookies refreshed by proxy.ts\nDATABASE (Postgres)\n\u2022 chat_sessions(id,user_id,title,\n   created_at,updated_at)\n\u2022 chat_messages(id,session_id,role,\n   content,created_at)\n\u2022 RLS: user_id = auth.uid()\nREALTIME\n\u2022 postgres_changes channel on\n   chat_sessions filtered by user_id \u2014\n   sidebar subscribes to live updates.",
      "lineHeight": 1.25,
      "autoResize": false
    },
