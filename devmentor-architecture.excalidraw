      "updated": 1714000000000,
      "link": null,
      "locked": false,
      "text": "RATE LIMIT\nsrc/lib/ai/rate-limit.ts\n\u2022 checkChatRateLimit(userId)\n   HEAD-count chat_messages WHERE\n   user_id=? AND role='user' AND\n   created_at >= now() - 1h\n\u2022 Compares to AI_LIMITS.\n   CHAT_MESSAGES_PER_HOUR (=50)\n\u2022 Returns {ok, remaining, resetMs}\nUsed only by /api/chat route.",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": "r-ratelimit",
      "originalText": "RATE LIMIT\nsrc/lib/ai/rate-limit.ts\n\u2022 checkChatRateLimit(userId)\n   HEAD-count chat_messages WHERE\n   user_id=? AND role='user' AND\n   created_at >= now() - 1h\n\u2022 Compares to AI_LIMITS.\n   CHAT_MESSAGES_PER_HOUR (=50)\n\u2022 Returns {ok, remaining, resetMs}\nUsed only by /api/chat route.",
      "lineHeight": 1.25,
      "autoResize": false
    },
