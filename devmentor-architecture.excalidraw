      "updated": 1714000000000,
      "link": null,
      "locked": false,
      "text": "useChat (CUSTOM HOOK)\nsrc/hooks/chat/use-chat.ts\nThin wrapper over @ai-sdk/react useChat\n+ DefaultChatTransport({api: '/api/chat',\n   prepareSendMessagesRequest: append\n   {sessionId, attachments}})\nState:\n\u2022 input (string)\n\u2022 attachments[] (ChatAttachment[])\nReturns: {messages, input, setInput,\n  attachments, setAttachments,\n  addAttachmentsFromFileList,\n  removeAttachment, handleSubmit,\n  isLoading, error, stop, sendMessage}\nKey fns:\n\u2022 handleSubmit(e) \u2014 sendMessage({text,files})\n\u2022 addAttachmentsFromFileList(list) \u2192\n   addFilesToChatAttachments + onError(code)\nProps: {api?, initialMessages?, sessionId?,\n  onError?, onFinish?}",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "useChat (CUSTOM HOOK)\nsrc/hooks/chat/use-chat.ts\nThin wrapper over @ai-sdk/react useChat\n+ DefaultChatTransport({api: '/api/chat',\n   prepareSendMessagesRequest: append\n   {sessionId, attachments}})\nState:\n\u2022 input (string)\n\u2022 attachments[] (ChatAttachment[])\nReturns: {messages, input, setInput,\n  attachments, setAttachments,\n  addAttachmentsFromFileList,\n  removeAttachment, handleSubmit,\n  isLoading, error, stop, sendMessage}\nKey fns:\n\u2022 handleSubmit(e) \u2014 sendMessage({text,files})\n\u2022 addAttachmentsFromFileList(list) \u2192\n   addFilesToChatAttachments + onError(code)\nProps: {api?, initialMessages?, sessionId?,\n  onError?, onFinish?}",
      "lineHeight": 1.25,
      "autoResize": false
    },
