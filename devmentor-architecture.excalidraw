    {
      "id": "t-future-rag",
      "type": "text",
      "x": 1488,
      "y": 2848,
      "width": 344,
      "height": 184,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 12006,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1714000000000,
      "link": null,
      "locked": false,
      "text": "PLANNED: RAG FEATURE  (next)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nWill plug in between /api/chat receiving\nthe message and streamText() being called:\n  query embeddings \u2192 Supabase pgvector\n  \u2192 top-k chunks \u2192 wrap with\n  RAG_SYSTEM_PROMPT(context).\nLikely new:\n\u2022 src/lib/ai/rag.ts (retriever)\n\u2022 src/lib/services/embeddings.service.ts\n\u2022 new Supabase tables: documents, chunks\n\u2022 ingest action / route",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "PLANNED: RAG FEATURE  (next)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nWill plug in between /api/chat receiving\nthe message and streamText() being called:\n  query embeddings \u2192 Supabase pgvector\n  \u2192 top-k chunks \u2192 wrap with\n  RAG_SYSTEM_PROMPT(context).\nLikely new:\n\u2022 src/lib/ai/rag.ts (retriever)\n\u2022 src/lib/services/embeddings.service.ts\n\u2022 new Supabase tables: documents, chunks\n\u2022 ingest action / route",
      "lineHeight": 1.25,
      "autoResize": false
    },
