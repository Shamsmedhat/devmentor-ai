    {
      "id": "t-ext-groq",
      "type": "text",
      "x": 1148,
      "y": 2848,
      "width": 304,
      "height": 164,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 12004,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1714000000000,
      "link": null,
      "locked": false,
      "text": "EXTERNAL: GROQ\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n@ai-sdk/groq \u2192 groq('llama-3.3-70b-versatile')\nUsed by /api/chat via Vercel AI SDK\nstreamText().\nReturns a streaming UIMessage response;\nuseChat consumes the protocol on the\nbrowser side.\n(Gemini provider is wired but commented\nout in route.ts.)",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": "r-ext-groq",
      "originalText": "EXTERNAL: GROQ\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n@ai-sdk/groq \u2192 groq('llama-3.3-70b-versatile')\nUsed by /api/chat via Vercel AI SDK\nstreamText().\nReturns a streaming UIMessage response;\nuseChat consumes the protocol on the\nbrowser side.\n(Gemini provider is wired but commented\nout in route.ts.)",
      "lineHeight": 1.25,
      "autoResize": false
    },
    {
      "id": "r-future-rag",
