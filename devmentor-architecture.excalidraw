    {
      "id": "t-i18n",
      "type": "text",
      "x": 208,
      "y": 2568,
      "width": 364,
      "height": 244,
      "angle": 0,
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 11002,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1714000000000,
      "link": null,
      "locked": false,
      "text": "i18n LAYER (next-intl)\nsrc/i18n/routing.ts\n\u2022 defineRouting({locales:['ar','en'],\n   defaultLocale:'ar', localePrefix:'always'})\nsrc/i18n/navigation.ts\n\u2022 createNavigation(routing) \u2192\n   {Link, redirect, usePathname,\n    useRouter, getPathname}\nsrc/i18n/request.ts\n\u2022 getRequestConfig(async ({requestLocale}))\n   \u2192 loads messages/${locale}.json,\n     resolves locale via hasLocale\nmessages/ar.json + messages/en.json\n   \u2192 all UI strings (landing, auth, chat).\nUsed by: proxy.ts (intl middleware),\n  layouts (NextIntlClientProvider),\n  every server/client component (useTranslations).",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "i18n LAYER (next-intl)\nsrc/i18n/routing.ts\n\u2022 defineRouting({locales:['ar','en'],\n   defaultLocale:'ar', localePrefix:'always'})\nsrc/i18n/navigation.ts\n\u2022 createNavigation(routing) \u2192\n   {Link, redirect, usePathname,\n    useRouter, getPathname}\nsrc/i18n/request.ts\n\u2022 getRequestConfig(async ({requestLocale}))\n   \u2192 loads messages/${locale}.json,\n     resolves locale via hasLocale\nmessages/ar.json + messages/en.json\n   \u2192 all UI strings (landing, auth, chat).\nUsed by: proxy.ts (intl middleware),\n  layouts (NextIntlClientProvider),\n  every server/client component (useTranslations).",
      "lineHeight": 1.25,
      "autoResize": false
    },
    {
