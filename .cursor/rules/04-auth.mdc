## proxy — Auth + i18n

```typescript
// proxy.ts
import { createServerClient } from "@supabase/ssr";
import createIntlproxy from "next-intl/proxy";
import { type NextRequest, NextResponse } from "next/server";
import { routing } from "./i18n/routing";

const intlproxy = createIntlproxy(routing);

const protectedRoutes = ["/chat", "/review", "/resources"];

export async function proxy(request: NextRequest) {
  const { pathname } = request.nextUrl;
  const isProtected = protectedRoutes.some((r) => pathname.includes(r));

  if (isProtected) {
    let response = NextResponse.next({ request });
    const supabase = createServerClient(
      process.env.NEXT_PUBLIC_SUPABASE_URL!,
      process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
      {
        cookies: {
          getAll: () => request.cookies.getAll(),
          setAll: (cookiesToSet) => {
            cookiesToSet.forEach(({ name, value, options }) =>
              response.cookies.set(name, value, options),
            );
          },
        },
      },
    );

    const {
      data: { user },
    } = await supabase.auth.getUser();
    if (!user) return NextResponse.redirect(new URL("/ar/login", request.url));
  }

  return intlproxy(request);
}

export const config = {
  matcher: [
    "/((?!api|_next|.*\\..*).*)",
    "/api/chat/:path*",
    "/api/review/:path*",
  ],
};
```

---

## Rules Summary

- ✅ Two Supabase clients: `client.ts` (browser) and `server.ts` (server)
- ✅ Always use `supabase.auth.getUser()` — not `getSession()` (more secure)
- ✅ Protect routes in `proxy.ts` — not inside pages
- ✅ OAuth callback route at `app/api/auth/callback/route.ts`
- ✅ Sign out via Server Action
- ❌ Never use service role key on the client
- ❌ Never trust client-side session alone — always verify on server
