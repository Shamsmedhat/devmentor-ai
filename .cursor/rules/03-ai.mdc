## Streaming Route Handler Pattern

```typescript
// app/api/chat/route.ts
import { createGoogleGenerativeAI } from "@ai-sdk/google";
import { streamText } from "ai";
import { createClient } from "@/utils/supabase/server";
import { MENTOR_SYSTEM_PROMPT } from "@/lib/ai/prompts";
import { retrieveContext } from "@/lib/ai/rag";

const google = createGoogleGenerativeAI({
  apiKey: process.env.GOOGLE_GENERATIVE_AI_API_KEY!,
});

export async function POST(req: Request) {
  // Auth check
  const supabase = await createClient();
  const { data: { user } } = await supabase.auth.getUser();
  if (!user) return new Response("Unauthorized", { status: 401 });

  const { messages } = await req.json();

  // Get last user message for RAG retrieval
  const lastMessage = messages[messages.length - 1]?.content ?? "";

  // RAG context retrieval
  const context = await retrieveContext(lastMessage);

  const result = streamText({
    model: google("gemini-2.0-flash"),
    system: context ? RAG_SYSTEM_PROMPT(context) : MENTOR_SYSTEM_PROMPT,
    messages,
    maxTokens: 1000,
    onFinish: async ({ text }) => {
      // Save to DB after stream completes
      await supabase.from("chat_messages").insert({
        user_id: user.id,
        role: "assistant",
        content: text,
      });
    },
  });

  return result.toDataStreamResponse();
}
```

