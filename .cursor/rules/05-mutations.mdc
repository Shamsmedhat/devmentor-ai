# Mutations Flow

Pattern: **Server Action → Custom Hook (useMutation) → Component**

No external REST API. All mutations go directly to Supabase.

---

## Layer 1 — Server Action

```typescript
// lib/actions/chat.action.ts
"use server";

import { createClient } from "@/utils/supabase/server";
import type { SaveMessageFields } from "@/lib/schemes/chat.schema";

export async function saveMessageAction(fields: SaveMessageFields) {
  const supabase = await createClient();
  const { data: { user } } = await supabase.auth.getUser();
  if (!user) throw new Error("Unauthorized");

  const { error } = await supabase.from("chat_messages").insert({
    ...fields,
    user_id: user.id,
  });

  if (error) throw new Error(error.message);
}
```

---

## Layer 2 — Custom Hook

```typescript
// hooks/chat/use-save-message.ts
"use client";

import { useMutation } from "@tanstack/react-query";
import { toast } from "sonner";
import { saveMessageAction } from "@/lib/actions/chat.action";
import type { SaveMessageFields } from "@/lib/schemes/chat.schema";

export function useSaveMessage() {
  const { isPending, mutate } = useMutation({
    mutationFn: (fields: SaveMessageFields) => saveMessageAction(fields),
    onError: (error) => {
      toast.error(error.message);
    },
  });

  return { isPending, saveMessage: mutate };
}
```

